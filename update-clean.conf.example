# Optional configuration for update-clean.sh
# Copy to one of:
#   /etc/update-clean.conf
#   ~/.config/update-clean.conf
#   ~/.update-clean.conf

# Number of log files to retain (default: 3)
# LOG_RETENTION=5

# Kernels to keep in addition to the running kernel (default: 2)
# KERNEL_KEEP=2

# Use --no-kernel on the command line to skip kernel cleanup entirely.
# /etc/update-clean.conf must be owned by root when installed system-wide.