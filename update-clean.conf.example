# Optional configuration for update-clean.sh
# Copy to one of:
#   /etc/update-clean.conf
#   ~/.config/update-clean.conf
#   ~/.update-clean.conf

# Number of log files to retain (default: 3)
# LOG_RETENTION=5

# Kernels to keep in addition to the running kernel (default: 2, max 10)
# KERNEL_KEEP=2

# Optional path overrides
# LOG_DIR=/var/log/update-clean
# LOCKFILE=/run/update-clean.lock
# LAST_RUN_DIR=/var/lib/update-clean

# Backup /etc before purging residual configs (default: false)
# BACKUP_MODE=true

# Reboot automatically when /var/run/reboot-required is set (default: false)
# REBOOT_IF_REQUIRED=true

# Optional completion email (requires mail command)
# ADMIN_EMAIL=admin@example.com

# Packages to hold during cleanup (default: base-files base-passwd bash coreutils util-linux)
# CRITICAL_PACKAGES=(base-files base-passwd bash coreutils util-linux)

# Use --no-kernel on the command line to skip kernel cleanup entirely.
# /etc/update-clean.conf must be owned by root when installed system-wide.